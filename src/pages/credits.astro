---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import MarqueeLights from '@components/MarqueeLights.astro';
import { creditGroups } from '@data/credits';
import { getProductionHref, getFeaturedThumbnail } from '@data/productions';
import goodmanPhoto from ‘../images/venues/goodman-theatre.jpg’;
import lyricPhoto from ‘../images/venues/lyric-opera.jpg’;
import oneillPhoto from ‘../images/venues/eugene-oneill-theatre.jpg’;
import steppenwolfPhoto from ‘../images/venues/steppenwolf-theatre.jpg’;
import wisdomBridgePhoto from ‘../images/falls-wisdom-bridge-rehearsal.jpg’;

const sectionIds: Record<string, string> = {
  ‘Broadway’: ‘broadway’,
  ‘Goodman Theatre’: ‘goodman’,
  ‘Wisdom Bridge Theatre’: ‘wisdom-bridge’,
  ‘Opera’: ‘opera’,
  ‘Recent Work’: ‘recent-work’,
};

const sectionPhotos: Record<string, { src: ImageMetadata; caption: string } | undefined> = {
  ‘Broadway’: { src: oneillPhoto, caption: "Eugene O’Neill Theatre, Broadway — site of his 1999 Tony Award" },
  ‘Goodman Theatre’: { src: goodmanPhoto, caption: "Goodman Theatre, Chicago — his artistic home for 35 years" },
  ‘Wisdom Bridge Theatre’: { src: wisdomBridgePhoto, caption: "Robert Falls in rehearsal, Wisdom Bridge Theatre, 1977–1985" },
  ‘Opera’: { src: lyricPhoto, caption: "Civic Opera Building, home of Lyric Opera of Chicago" },
  ‘Recent Work’: { src: steppenwolfPhoto, caption: "Steppenwolf Theatre Company, Chicago" },
};
---

<BaseLayout
  title="Credits — Robert Falls"
  description="Selected directing credits of Robert Falls across Broadway, the Goodman Theatre, Wisdom Bridge Theatre, and opera."
>
  <section class="bg-brand-ink text-brand-cream relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(138,19,36,0.38),_transparent_55%),radial-gradient(ellipse_at_bottom_right,_rgba(138,19,36,0.14),_transparent_45%)]"></div>
    <div class="grain-overlay"></div>
    <div class="relative pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="section-container !py-0">
        <p class="section-eyebrow text-brand-gold">A Working Life</p>
        <h1 class="font-display font-extrabold text-6xl md:text-8xl tracking-tight">Selected Credits</h1>
        <p class="font-serif italic text-brand-cream/70 text-lg mt-6 max-w-xl">
          Sixteen Broadway stagings, decades of world premieres at the Goodman, a Tony Award,
          and a directing career that began with amateur productions in rural Illinois. For the
          complete chronological record, see the <a href="/timeline" class="underline underline-offset-4 hover:text-brand-goldBright">full career timeline</a>.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/productions" class="btn-primary">Browse Production Pages</a>
          <a href="/timeline" class="btn-outline border-brand-cream/30 text-brand-cream hover:border-brand-gold hover:text-brand-goldBright">
            Career Timeline
          </a>
        </div>
      </div>
      <MarqueeLights class="mt-12" />
    </div>
  </section>

  <!-- QUICK JUMP NAV -->
  <nav class="bg-brand-cream border-b border-brand-ink/10 sticky top-20 md:top-24 z-30 backdrop-blur-sm" aria-label="Jump to venue">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center gap-x-5 gap-y-1 flex-wrap text-xs">
      <span class="uppercase tracking-[0.16em] text-brand-ink/40 hidden sm:inline">Jump to</span>
      {creditGroups.map((group) => (
        <a
          href={`#${sectionIds[group.label]}`}
          class="font-display font-semibold uppercase tracking-[0.14em] text-brand-oxblood/75 hover:text-brand-oxblood transition-colors"
        >
          {group.label}
        </a>
      ))}
    </div>
  </nav>

  {creditGroups.map((group) => {
    const photo = sectionPhotos[group.label];
    return (
      <section id={sectionIds[group.label]} class="border-b border-brand-ink/10 last:border-0 scroll-mt-32 md:scroll-mt-36">
        <!-- VENUE BANNER -->
        <div class="relative h-72 md:h-[26rem] overflow-hidden bg-brand-oxbloodDeep">
          {photo ? (
            <Image
              src={photo.src}
              alt={photo.caption}
              widths={[640, 960, 1280, 1600, 1920]}
              sizes="100vw"
              quality={74}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover scale-[1.04]"
            />
          ) : (
            <div class="grain-overlay"></div>
          )}
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(12,9,8,0.97) 0%, rgba(12,9,8,0.55) 40%, transparent 72%);"></div>
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(12,9,8,0.55) 0%, transparent 55%);"></div>
          <div class="absolute inset-0" style="box-shadow: inset 0 0 100px 20px rgba(12,9,8,0.42);"></div>
          <div class="grain-overlay opacity-30"></div>
          <div class="relative h-full max-w-6xl mx-auto px-6 flex flex-col justify-end pb-8">
            <h2 class="font-display text-5xl md:text-6xl text-brand-cream tracking-tight">{group.label}</h2>
            <div class="flex items-center gap-3 mt-3">
              <span class="text-xs uppercase tracking-[0.18em] text-brand-goldBright font-semibold">{group.count}</span>
              {photo && <span class="text-xs text-brand-cream/50 hidden md:inline">{photo.caption}</span>}
            </div>
          </div>
        </div>

        <!-- CREDIT LIST -->
        <div class="section-container !pt-10">
          <div class="divide-y divide-brand-ink/10">
            {group.credits.map((credit) => {
              const thumbnail = getFeaturedThumbnail(credit.title);
              return (
                <div class="py-4 flex items-center gap-4">
                  {thumbnail ? (
                    <a href={getProductionHref(credit.title)} class="shrink-0 block w-14 h-14 overflow-hidden bg-brand-ink/5">
                      <Image
                        src={thumbnail.src}
                        alt=""
                        widths={[112]}
                        sizes="56px"
                        quality={72}
                        loading="lazy"
                        class="w-full h-full object-cover"
                      />
                    </a>
                  ) : (
                    <span class="shrink-0 block w-1.5 h-1.5 rounded-full bg-brand-oxblood/40 ml-1.5 mr-1.5" aria-hidden="true"></span>
                  )}
                  <div class="flex-1 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 min-w-0">
                    <div class="min-w-0">
                      <a
                        href={getProductionHref(credit.title)}
                        class="font-serif text-xl text-brand-ink hover:text-brand-oxblood transition-colors"
                      >
                        {credit.title}
                      </a>
                      <span class="text-brand-ink/65 text-sm ml-3">{credit.venue}</span>
                    </div>
                    <div class="flex items-center gap-4 shrink-0">
                      {credit.note && <span class="text-sm italic text-brand-oxblood/80">{credit.note}</span>}
                      <span class="text-sm text-brand-ink/65 font-display tracking-wide">{credit.year}</span>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    );
  })}

  <section class="bg-brand-oxbloodDeep text-brand-cream text-center py-16">
    <p class="font-serif italic text-xl text-brand-cream/85 max-w-xl mx-auto px-6">
      This page highlights selected work by venue. For every production in chronological order,
      visit the <a href="/timeline" class="text-brand-goldBright underline underline-offset-4">full career timeline</a>,
      or <a href="/contact" class="text-brand-goldBright underline underline-offset-4">get in touch</a> directly.
    </p>
  </section>
</BaseLayout>
