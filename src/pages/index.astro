---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import MarqueeLights from '@components/MarqueeLights.astro';
import { getProductionBySlug, getProductionHref, productionStats } from '@data/productions';
import rehearsalPhoto from '../images/robert-falls-rehearsal.jpg';
import heroBackground from '../images/falls-rehearsal-recent.jpg';

// Editorially curated, but every displayed field (title, image, dates) is pulled
// live from the production archive so this can never drift out of sync with it.
const nowAndUpcomingSeeds = [
  {
    slug: 'don-giovanni',
    statusLabel: 'Upcoming' as const,
    status: 'Opens October 10, 2026',
    note: "Lyric Opera of Chicago's third revival of his 2014 staging",
  },
  {
    slug: 'holiday',
    statusLabel: 'Completed' as const,
    status: 'Goodman Theatre · Winter 2026',
    note: 'His first Goodman production since stepping down as Artistic Director',
  },
  {
    slug: 'amadeus',
    statusLabel: 'Completed' as const,
    status: 'Steppenwolf Theatre · 2025',
    note: 'His Steppenwolf directorial debut',
  },
];

const nowAndUpcoming = nowAndUpcomingSeeds
  .map(({ slug, statusLabel, status, note }) => {
    const production = getProductionBySlug(slug);
    const thumbnail = production?.images[0];
    if (!production || !thumbnail) return null;
    return { title: production.title, statusLabel, status, note, thumbnail, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);

const activeShows    = nowAndUpcoming.filter((p) => p.statusLabel !== 'Completed');
const recentlyShows  = nowAndUpcoming.filter((p) => p.statusLabel === 'Completed');

const gallerySlugs = [
  'death-of-a-salesman',
  'the-iceman-cometh',
  'king-lear',
  'luna-gale',
  'uncle-vanya',
  'the-seagull',
  '2666',
  'the-cherry-orchard',
];
const selectedProductions = gallerySlugs
  .map((slug) => {
    const production = getProductionBySlug(slug);
    const thumbnail = production?.images[0];
    if (!production || !thumbnail) return null;
    return { title: production.title, venue: production.venueAnchor, year: production.yearSpan, thumbnail, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);

---

<BaseLayout
  title="Robert Falls — Theatre Director"
  description="Robert Falls, Tony Award-winning theatre director and Artistic Director of Chicago's Goodman Theatre for 35 years — currently directing a third Lyric Opera revival of Don Giovanni, opening October 2026."
  transparentHeader={true}
>
  <!-- HERO -->
  <section class="relative bg-brand-ink text-brand-cream overflow-hidden">
    <Image
      src={heroBackground}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600, 2000]}
      sizes="100vw"
      quality={76}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.28] mix-blend-luminosity pointer-events-none"
    />
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(90deg, rgba(12,9,8,0.97) 0%, rgba(12,9,8,0.88) 30%, rgba(12,9,8,0.52) 58%, rgba(12,9,8,0.92) 100%), linear-gradient(180deg, rgba(12,9,8,0.65) 0%, transparent 28%, transparent 60%, rgba(12,9,8,1) 100%);"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_22%,rgba(138,19,36,0.30),transparent_34%)] pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 130px 22px rgba(12,9,8,0.48);"></div>
    <div class="grain-overlay"></div>

    <div class="relative pt-32 pb-10 md:pt-44 md:pb-14">
      <MarqueeLights class="mb-12 md:mb-16" />
      <div class="max-w-6xl mx-auto px-6">
        <p class="section-eyebrow text-brand-gold">Tony Award-Winning Director</p>
        <h1 class="font-display font-extrabold leading-[0.85] tracking-tight text-[16vw] md:text-[9rem] lg:text-[10.5rem]">
          ROBERT<br /><span class="text-brand-oxbloodBright">FALLS</span>
        </h1>
        <div class="mt-7 flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.72rem] md:text-[0.82rem] font-display font-semibold uppercase tracking-[0.28em] text-brand-cream/58">
          <span>Wisdom Bridge</span>
          <span class="hidden sm:inline text-brand-gold/55">/</span>
          <span>Goodman Theatre</span>
          <span class="hidden sm:inline text-brand-gold/55">/</span>
          <span>Broadway</span>
          <span class="hidden sm:inline text-brand-gold/55">/</span>
          <span>Opera</span>
        </div>
        <p class="font-serif italic text-lg md:text-[1.55rem] text-brand-cream/75 mt-5 max-w-2xl leading-relaxed">
          Five decades shaping the American stage &mdash; from Wisdom Bridge through a landmark Goodman era,
          and now, directing new work in Chicago and beyond.
        </p>

        <div class="flex flex-wrap gap-4 mt-10">
          <a href="#now" class="btn-primary">See What's Now</a>
          <a href="/about" class="border border-brand-cream/30 text-brand-cream font-display uppercase tracking-[0.12em] text-sm font-semibold px-7 py-3.5 hover:border-brand-gold hover:text-brand-goldBright transition-colors">
            About Robert
          </a>
        </div>
      </div>
      <MarqueeLights class="mt-14 md:mt-20" />
    </div>
  </section>

  <!-- NOW & UPCOMING -->
  <section id="now" class="bg-brand-cream border-b border-brand-ink/10">
    <div class="section-container">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-10">
        <div>
          <p class="section-eyebrow">Now &amp; Upcoming</p>
          <h2 class="section-heading">Still Directing<span class="text-brand-oxblood">.</span></h2>
        </div>
        <p class="font-serif italic text-brand-ink/60 text-lg max-w-sm">
          "I feel very lucky that I can be selective. I want to continue to work on exciting projects."
        </p>
      </div>
      {activeShows.length > 0 && (
        <div class:list={['grid gap-6 mb-10', activeShows.length === 1 ? 'max-w-xs' : 'sm:grid-cols-3']}>
          {activeShows.map((item) => (
            <a href={item.href} class="group block">
              <div class="aspect-[3/4] overflow-hidden bg-brand-ink relative mb-4">
                <Image
                  src={item.thumbnail.src}
                  alt={item.thumbnail.alt}
                  widths={[320, 480, 640, 960]}
                  sizes="(max-width: 639px) 100vw, 33vw"
                  quality={76}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
                />
                <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(12,9,8,0.72) 0%, rgba(12,9,8,0.18) 40%, transparent 70%);"></div>
                <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 60px 10px rgba(12,9,8,0.38);"></div>
                <div class="absolute top-3 left-3">
                  <span class:list={[
                    'inline-flex items-center px-2.5 py-1 font-display text-[10px] font-semibold uppercase tracking-[0.18em]',
                    item.statusLabel === 'Upcoming' && 'bg-brand-gold text-brand-ink',
                    item.statusLabel === 'Running'  && 'bg-brand-oxbloodBright text-brand-cream',
                  ]}>
                    {item.statusLabel}
                  </span>
                </div>
              </div>
              <div class="font-display text-2xl text-brand-ink leading-tight group-hover:text-brand-oxblood transition-colors">
                {item.title}
              </div>
              <div class="text-xs uppercase tracking-[0.16em] text-brand-ink/55 font-semibold mt-2">{item.status}</div>
              <p class="text-sm text-brand-ink/60 mt-1 leading-snug">{item.note}</p>
            </a>
          ))}
        </div>
      )}

      {recentlyShows.length > 0 && (
        <div class="border-t border-brand-ink/10 pt-8 mb-10">
          <p class="text-[11px] uppercase tracking-[0.2em] text-brand-ink/40 font-semibold mb-5">Recently Completed</p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {recentlyShows.map((item) => (
              <a href={item.href} class="group flex items-center gap-4 border border-brand-ink/10 bg-white/70 px-4 py-3 hover:border-brand-oxblood/25 transition-colors">
                <div class="w-12 h-16 shrink-0 overflow-hidden bg-brand-ink">
                  <Image
                    src={item.thumbnail.src}
                    alt=""
                    widths={[48, 96]}
                    sizes="48px"
                    quality={72}
                    loading="lazy"
                    class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
                  />
                </div>
                <div class="min-w-0">
                  <div class="font-display text-base text-brand-ink/50 leading-tight truncate group-hover:text-brand-ink transition-colors">{item.title}</div>
                  <div class="text-[10px] uppercase tracking-[0.16em] text-brand-ink/35 mt-1">{item.status}</div>
                </div>
                <span class="ml-auto shrink-0 inline-flex items-center px-2 py-0.5 font-display text-[9px] font-semibold uppercase tracking-[0.14em] border border-brand-ink/12 text-brand-ink/35">
                  Completed
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="flex items-center justify-center">
        <a href="/credits#recent-work" class="btn-outline">See Recent &amp; Current Work</a>
      </div>
    </div>
  </section>

  <!-- SELECTED PRODUCTIONS GALLERY -->
  <section class="bg-brand-cream border-y border-brand-ink/10">
    <div class="section-container">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
        <div>
          <p class="section-eyebrow">Five Decades on Stage</p>
          <h2 class="section-heading">Selected Productions</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.16em] text-brand-ink/60 max-w-xs text-right hidden sm:block">
          {productionStats.titleCount}+ productions documented, {productionStats.earliestYear}–{productionStats.latestYear}
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {selectedProductions.map((production) => (
          <a href={production.href} class="group block">
            <div class="aspect-[3/4] overflow-hidden bg-brand-ink relative mb-3">
              <Image
                src={production.thumbnail.src}
                alt={production.thumbnail.alt}
                widths={[240, 360, 480, 720]}
                sizes="(max-width: 639px) 50vw, 25vw"
                quality={76}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
              />
              <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(12,9,8,0.65) 0%, rgba(12,9,8,0.12) 38%, transparent 65%);"></div>
              <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 50px 8px rgba(12,9,8,0.35);"></div>
            </div>
            <div class="font-display text-base text-brand-ink leading-tight group-hover:text-brand-oxblood transition-colors">
              {production.title}
            </div>
            <div class="text-[10px] uppercase tracking-[0.16em] text-brand-ink/60 mt-1">
              {production.venue} · {production.year}
            </div>
          </a>
        ))}
      </div>
      <div class="flex items-center justify-center mt-10">
        <a href="/productions" class="btn-outline">Browse the Full Productions Archive</a>
      </div>
    </div>
  </section>

  <!-- THE GOODMAN YEARS -->
  <section class="bg-brand-oxbloodDeep text-brand-cream relative overflow-hidden">
    <Image
      src={rehearsalPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={72}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-25 mix-blend-luminosity"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-oxbloodDeep via-brand-oxbloodDeep/95 to-brand-oxbloodDeep/70"></div>
    <div class="grain-overlay"></div>
    <div class="section-container relative">
      <p class="section-eyebrow text-brand-gold">1986 &mdash; 2022</p>
      <h2 class="section-heading text-brand-cream">The Goodman Years</h2>
      <p class="text-brand-cream/75 leading-relaxed max-w-2xl mb-10">
        Robert's Goodman tenure reshaped the theatre's national profile, pairing ambitious new work
        with major transfers and a durable Chicago identity. Under his leadership the Goodman received
        the Special Tony Award for Outstanding Regional Theatre, was named the top regional theater in
        the country by <em class="font-serif italic">Time</em>, and opened its downtown Loop campus with the
        Robert Falls Rehearsal Wing bearing his name.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-10">
        <div class="border border-brand-cream/16 bg-brand-cream/[0.04] px-5 py-5">
          <div class="font-display text-4xl text-brand-goldBright leading-none">35</div>
          <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-brand-cream/60">Years as Artistic Director</div>
        </div>
        <div class="border border-brand-cream/16 bg-brand-cream/[0.04] px-5 py-5">
          <div class="font-display text-4xl text-brand-goldBright leading-none">150+</div>
          <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-brand-cream/60">World premieres produced</div>
        </div>
        <div class="border border-brand-cream/16 bg-brand-cream/[0.04] px-5 py-5">
          <div class="font-display text-4xl text-brand-goldBright leading-none">22</div>
          <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-brand-cream/60">Tony Awards for Broadway transfers</div>
        </div>
        <div class="border border-brand-cream/16 bg-brand-cream/[0.04] px-5 py-5">
          <div class="font-display text-4xl text-brand-goldBright leading-none">#1</div>
          <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-brand-cream/60">Regional theater in the U.S. — <em class="font-serif not-italic">Time</em></div>
        </div>
      </div>
      <a href="/credits#goodman" class="btn-primary mt-10 inline-flex">Full Goodman Credits</a>
    </div>
  </section>

</BaseLayout>
