<script>
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-strip-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-strip-next]');
  const strip = document.querySelector<HTMLElement>('[data-asset-strip]');

  if (strip && prevBtn && nextBtn) {
    const cardWidth = () => {
      const card = strip.querySelector<HTMLElement>('.production-asset-card, .production-watch-card');
      return card ? card.offsetWidth + 16 : 340;
    };

    const update = () => {
      prevBtn.disabled = strip.scrollLeft < 8;
      nextBtn.disabled = strip.scrollLeft + strip.clientWidth >= strip.scrollWidth - 8;
    };

    prevBtn.addEventListener('click', () => strip.scrollBy({ left: -cardWidth(), behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => strip.scrollBy({ left: cardWidth(), behavior: 'smooth' }));
    strip.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
