---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import rehearsalPhoto from '../images/falls-rehearsal-recent.jpg';
---

<BaseLayout
  title="Contact - Robert Falls"
  description="Get in touch with Robert Falls for booking, media inquiries, and representation."
>
  <section class="bg-brand-ink text-brand-cream relative overflow-hidden">
    <Image
      src={rehearsalPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={68}
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.16] mix-blend-luminosity pointer-events-none"
    />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(138,19,36,0.28),_transparent_48%),linear-gradient(150deg,rgba(12,9,8,0.94),rgba(24,16,12,0.84))]"></div>
    <div class="grain-overlay"></div>
    <div class="relative pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="section-container !py-0">
        <p class="section-eyebrow text-brand-gold">Get in Touch</p>
        <h1 class="font-display font-extrabold text-6xl md:text-8xl tracking-tight">Contact</h1>
        <p class="mt-5 max-w-3xl text-brand-cream/72 leading-relaxed">
          Booking, media, and general archive inquiries are all routed through this page. Choose the closest
          subject line, include the basics up front, and the request can be forwarded cleanly.
        </p>
      </div>
    </div>
  </section>

  <section class="section-container grid gap-14 lg:grid-cols-[minmax(0,1fr)_28rem]">
    <div>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
        <div>
          <p class="section-eyebrow">Inquiry Paths</p>
          <h2 class="section-heading">What This Page Handles</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.18em] text-brand-ink/55">
          choose the closest request type
        </div>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        <div class="border border-brand-ink/12 bg-white p-6">
          <h3 class="text-xs uppercase tracking-[0.18em] text-brand-oxblood font-semibold mb-3">Representation &amp; Booking</h3>
          <p class="text-brand-ink/72 text-sm leading-relaxed">
            For directing invitations, producing conversations, festival appearances, and booking requests.
          </p>
          <div class="mt-4 text-[11px] uppercase tracking-[0.16em] text-brand-ink/50">Use subject: Booking / Representation</div>
          <a href="#contact-form" class="inline-flex mt-4 text-sm font-semibold text-brand-oxblood hover:text-brand-oxbloodBright transition-colors">
            Start a booking inquiry &rarr;
          </a>
        </div>

        <div class="border border-brand-ink/12 bg-white p-6">
          <h3 class="text-xs uppercase tracking-[0.18em] text-brand-oxblood font-semibold mb-3">Media &amp; Press</h3>
          <p class="text-brand-ink/72 text-sm leading-relaxed">
            For interviews, biographies, headshots, approved production photography, and publicity requests.
          </p>
          <div class="mt-4 text-[11px] uppercase tracking-[0.16em] text-brand-ink/50">Use subject: Media / Press</div>
          <div class="flex flex-wrap gap-4 mt-4">
            <a href="/press" class="inline-flex text-sm font-semibold text-brand-oxblood hover:text-brand-oxbloodBright transition-colors">
              Open press page &rarr;
            </a>
            <a href="#contact-form" class="inline-flex text-sm font-semibold text-brand-ink/70 hover:text-brand-oxblood transition-colors">
              Send request &rarr;
            </a>
          </div>
        </div>

        <div class="border border-brand-ink/12 bg-white p-6 md:col-span-2 xl:col-span-1">
          <h3 class="text-xs uppercase tracking-[0.18em] text-brand-oxblood font-semibold mb-3">General Inquiry</h3>
          <p class="text-brand-ink/72 text-sm leading-relaxed">
            For archive questions, speaking requests, permissions questions, and anything that does not fit the other lanes.
          </p>
          <div class="mt-4 text-[11px] uppercase tracking-[0.16em] text-brand-ink/50">Use subject: General Inquiry</div>
          <a href="#contact-form" class="inline-flex mt-4 text-sm font-semibold text-brand-oxblood hover:text-brand-oxbloodBright transition-colors">
            Send a message &rarr;
          </a>
        </div>
      </div>

      <div class="mt-8 border border-brand-ink/12 bg-brand-cream/70 p-6">
        <h3 class="text-xs uppercase tracking-[0.18em] text-brand-oxblood font-semibold mb-3">What to include</h3>
        <ul class="grid gap-3 md:grid-cols-2 text-sm leading-relaxed text-brand-ink/72">
          <li>Who you are and the organization or publication you represent.</li>
          <li>What the request is for and any relevant production title.</li>
          <li>Your deadline, proposed dates, and the best way to reply.</li>
          <li>Venue, city, producing organization, and timeline for booking requests.</li>
        </ul>
      </div>
    </div>

    <div id="contact-form" class="border border-brand-ink/12 bg-white p-6 md:p-7 self-start">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <p class="section-eyebrow">Message Form</p>
          <h2 class="font-display text-3xl text-brand-ink">Send a Message</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.18em] text-brand-ink/45">
          route it cleanly the first time
        </div>
      </div>
      <form
        method="POST"
        action="/contact/success/"
        name="contact"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <div>
          <label for="name" class="block text-sm font-medium text-brand-ink mb-1">Name</label>
          <input
            type="text" id="name" name="name" required
            class="w-full border border-brand-ink/20 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-oxblood bg-white"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-brand-ink mb-1">Email</label>
          <input
            type="email" id="email" name="email" required
            class="w-full border border-brand-ink/20 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-oxblood bg-white"
          />
        </div>
        <div>
          <label for="subject" class="block text-sm font-medium text-brand-ink mb-1">Subject</label>
          <select
            id="subject" name="subject"
            class="w-full border border-brand-ink/20 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-oxblood bg-white"
          >
            <option>Booking / Representation</option>
            <option>Media / Press</option>
            <option>General Inquiry</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-brand-ink mb-1">Message</label>
          <textarea
            id="message" name="message" rows="6" required
            class="w-full border border-brand-ink/20 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-oxblood bg-white resize-y"
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full justify-center">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>
