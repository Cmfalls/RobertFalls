---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import MarqueeLights from '@components/MarqueeLights.astro';
import { awards } from '@data/awards';
import { getProductionBySlug, getProductionHref, productionStats } from '@data/productions';
import { pressItems } from '@data/press';
import rehearsalPhoto from '../images/robert-falls-rehearsal.jpg';
import kingLearPhoto from '../images/king-lear/king-lear-1.webp';
import portraitAlt from '../images/robert-falls-portrait-2025-alt.jpg';
import heroBackground from '../images/falls-rehearsal-recent.jpg';

const featuredAwardNames = [
  'Tony Award, Best Direction of a Play',
  'Special Tony Award, Outstanding Regional Theatre',
  'Drama Desk Award, Outstanding Director of a Play',
  'Theater Hall of Fame Induction',
];
const featuredAwards = featuredAwardNames.map((name) => awards.find((a) => a.name === name)!);
const featuredPress = pressItems.slice(0, 3);

// Editorially curated, but every displayed field (title, image, dates) is pulled
// live from the production archive so this can never drift out of sync with it.
const nowAndUpcoming = [
  {
    slug: 'don-giovanni',
    status: 'Opens October 10, 2026',
    note: "Lyric Opera of Chicago's third revival of his 2014 staging",
  },
  {
    slug: 'holiday',
    status: "Goodman Theatre, Centennial Season",
    note: 'His first Goodman production since stepping down as Artistic Director',
  },
  {
    slug: 'amadeus',
    status: 'Steppenwolf Theatre, 2025',
    note: 'His Steppenwolf directorial debut',
  },
]
  .map(({ slug, status, note }) => {
    const production = getProductionBySlug(slug);
    const thumbnail = production?.images[0];
    if (!production || !thumbnail) return null;
    return { title: production.title, status, note, thumbnail, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);

const goodmanHighlightSlugs = ['death-of-a-salesman', 'the-iceman-cometh', 'king-lear', 'finishing-the-picture'];
const goodmanHighlights = goodmanHighlightSlugs
  .map((slug) => {
    const production = getProductionBySlug(slug);
    if (!production) return null;
    return { title: production.title, meta: `${production.yearSpan} · ${production.venueAnchor}`, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);

const gallerySlugs = [
  'death-of-a-salesman',
  'the-iceman-cometh',
  'king-lear',
  'luna-gale',
  'uncle-vanya',
  'the-seagull',
  '2666',
  'the-cherry-orchard',
];
const selectedProductions = gallerySlugs
  .map((slug) => {
    const production = getProductionBySlug(slug);
    const thumbnail = production?.images[0];
    if (!production || !thumbnail) return null;
    return { title: production.title, venue: production.venueAnchor, year: production.yearSpan, thumbnail, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);

// Critical praise wall: each entry names a real production and the index of a real,
// already-sourced quote on that page, so the homepage can never show invented praise.
const criticalPraisePicks = [
  { slug: 'the-iceman-cometh', index: 1 },
  { slug: 'luna-gale', index: 2 },
  { slug: 'desire-under-the-elms', index: 1 },
  { slug: 'pamplona', index: 0 },
  { slug: 'the-seagull', index: 1 },
  { slug: 'the-winters-tale', index: 1 },
];
const criticalPraise = criticalPraisePicks
  .map(({ slug, index }) => {
    const production = getProductionBySlug(slug);
    const pressQuote = production?.pressQuotes[index];
    if (!production || !pressQuote) return null;
    return { quote: pressQuote.quote, source: pressQuote.source, title: production.title, href: getProductionHref(production.title) };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);
---

<BaseLayout
  title="Robert Falls — Theatre Director"
  description="Robert Falls, Tony Award-winning theatre director and Artistic Director of Chicago's Goodman Theatre for 35 years — currently directing a third Lyric Opera revival of Don Giovanni, opening October 2026."
  transparentHeader={true}
>
  <!-- HERO -->
  <section class="relative bg-brand-ink text-brand-cream overflow-hidden">
    <Image
      src={heroBackground}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600, 2000]}
      sizes="100vw"
      quality={76}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.28] mix-blend-luminosity pointer-events-none"
    />
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(90deg, rgba(12,9,8,0.97) 0%, rgba(12,9,8,0.88) 30%, rgba(12,9,8,0.52) 58%, rgba(12,9,8,0.92) 100%), linear-gradient(180deg, rgba(12,9,8,0.65) 0%, transparent 28%, transparent 60%, rgba(12,9,8,1) 100%);"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_22%,rgba(138,19,36,0.30),transparent_34%)] pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 130px 22px rgba(12,9,8,0.48);"></div>
    <div class="grain-overlay"></div>

    <div class="relative pt-32 pb-10 md:pt-44 md:pb-14">
      <MarqueeLights class="mb-12 md:mb-16" />
      <div class="max-w-6xl mx-auto px-6">
        <p class="section-eyebrow text-brand-gold">Tony Award-Winning Director</p>
        <h1 class="font-display font-extrabold leading-[0.85] tracking-tight text-[16vw] md:text-[9rem] lg:text-[10.5rem]">
          ROBERT<br /><span class="text-brand-oxbloodBright">FALLS</span>
        </h1>
        <p class="font-serif italic text-xl md:text-2xl text-brand-cream/75 mt-8 max-w-2xl">
          Five decades shaping the American stage — from Wisdom Bridge to thirty-five years
          leading Chicago's Goodman Theatre, and now, directing new work in Chicago and beyond.
        </p>

        <div class="flex flex-wrap gap-4 mt-10">
          <a href="#now" class="btn-primary">See What's Now</a>
          <a href="/about" class="border border-brand-cream/30 text-brand-cream font-display uppercase tracking-[0.12em] text-sm font-semibold px-7 py-3.5 hover:border-brand-gold hover:text-brand-goldBright transition-colors">
            About Robert
          </a>
        </div>
      </div>
      <MarqueeLights class="mt-14 md:mt-20" />
    </div>
  </section>

  <!-- NOW & UPCOMING -->
  <section id="now" class="bg-brand-cream border-b border-brand-ink/10">
    <div class="section-container">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-10">
        <div>
          <p class="section-eyebrow">Now &amp; Upcoming</p>
          <h2 class="section-heading">Still Directing<span class="text-brand-oxblood">.</span></h2>
        </div>
        <p class="font-serif italic text-brand-ink/60 text-lg max-w-sm">
          "I feel very lucky that I can be selective. I want to continue to work on exciting projects."
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {nowAndUpcoming.map((item) => (
          <a href={item.href} class="group block">
            <div class="aspect-[3/4] overflow-hidden bg-brand-ink relative mb-4">
              <Image
                src={item.thumbnail.src}
                alt={item.thumbnail.alt}
                widths={[320, 480, 640, 960]}
                sizes="(max-width: 639px) 100vw, 33vw"
                quality={76}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
              />
              <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(12,9,8,0.72) 0%, rgba(12,9,8,0.18) 40%, transparent 70%);"></div>
              <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 60px 10px rgba(12,9,8,0.38);"></div>
            </div>
            <div class="font-display text-2xl text-brand-ink leading-tight group-hover:text-brand-oxblood transition-colors">
              {item.title}
            </div>
            <div class="text-xs uppercase tracking-[0.16em] text-brand-oxblood font-semibold mt-2">{item.status}</div>
            <p class="text-sm text-brand-ink/60 mt-1 leading-snug">{item.note}</p>
          </a>
        ))}
      </div>
      <div class="flex items-center justify-center mt-12">
        <a href="/credits#recent-work" class="btn-outline">See Recent &amp; Current Work</a>
      </div>
    </div>
  </section>

  <!-- SELECTED PRODUCTIONS GALLERY -->
  <section class="bg-brand-cream border-y border-brand-ink/10">
    <div class="section-container">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
        <div>
          <p class="section-eyebrow">Five Decades on Stage</p>
          <h2 class="section-heading">Selected Productions</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.16em] text-brand-ink/60 max-w-xs text-right hidden sm:block">
          {productionStats.titleCount}+ productions documented, {productionStats.earliestYear}–{productionStats.latestYear}
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {selectedProductions.map((production) => (
          <a href={production.href} class="group block">
            <div class="aspect-[3/4] overflow-hidden bg-brand-ink relative mb-3">
              <Image
                src={production.thumbnail.src}
                alt={production.thumbnail.alt}
                widths={[240, 360, 480, 720]}
                sizes="(max-width: 639px) 50vw, 25vw"
                quality={76}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
              />
              <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(12,9,8,0.65) 0%, rgba(12,9,8,0.12) 38%, transparent 65%);"></div>
              <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 50px 8px rgba(12,9,8,0.35);"></div>
            </div>
            <div class="font-display text-base text-brand-ink leading-tight group-hover:text-brand-oxblood transition-colors">
              {production.title}
            </div>
            <div class="text-[10px] uppercase tracking-[0.16em] text-brand-ink/60 mt-1">
              {production.venue} · {production.year}
            </div>
          </a>
        ))}
      </div>
      <div class="flex items-center justify-center mt-10">
        <a href="/productions" class="btn-outline">Browse the Full Productions Archive</a>
      </div>
    </div>
  </section>

  <!-- THE GOODMAN YEARS -->
  <section class="bg-brand-oxbloodDeep text-brand-cream relative overflow-hidden">
    <Image
      src={rehearsalPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={72}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover opacity-25 mix-blend-luminosity"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-oxbloodDeep via-brand-oxbloodDeep/95 to-brand-oxbloodDeep/70"></div>
    <div class="grain-overlay"></div>
    <div class="section-container relative">
      <p class="section-eyebrow text-brand-gold">1986 &mdash; 2022</p>
      <h2 class="section-heading text-brand-cream">The Goodman Years</h2>
      <p class="text-brand-cream/75 leading-relaxed max-w-2xl mb-10">
        Over thirty-five years as Artistic Director, Robert transformed Chicago's Goodman Theatre
        into one of the nation's leading arts institutions — producing over one hundred fifty world
        premieres and twenty-four Broadway transfers that together earned twenty-two Tony Awards.
        Under his leadership the Goodman received the Special Tony Award for Outstanding Regional
        Theatre and was named the number one regional theater in the U.S. by <em class="font-serif italic">Time</em>.
        When the Goodman opened its downtown Loop campus in 2000, the building's rehearsal hall was
        named the Robert Falls Rehearsal Wing in his honor — a lasting, physical mark of his tenure.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {goodmanHighlights.map((item) => (
          <a href={item.href} class="border border-brand-cream/15 p-6 hover:border-brand-gold transition-colors group">
            <div class="font-display text-2xl text-brand-goldBright mb-1 group-hover:text-brand-cream transition-colors">{item.title}</div>
            <div class="text-xs uppercase tracking-[0.16em] text-brand-cream/60">{item.meta}</div>
          </a>
        ))}
      </div>
      <a href="/credits#goodman" class="btn-primary mt-10 inline-flex">Full Goodman Credits</a>
    </div>
  </section>

  <!-- CRITICAL PRAISE -->
  <section class="relative overflow-hidden bg-brand-cream">
    <Image
      src={kingLearPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={60}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.07] mix-blend-multiply pointer-events-none"
    />
    <div class="section-container relative">
      <p class="section-eyebrow">Five Decades of Notices</p>
      <h2 class="section-heading">Critical Praise<span class="text-brand-oxblood">.</span></h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-ink/10 mt-8">
        {criticalPraise.map((item) => (
          <a href={item.href} class="bg-brand-cream p-6 hover:bg-white transition-colors group flex flex-col">
            <p class="font-serif italic text-brand-ink text-lg leading-snug flex-1">&ldquo;{item.quote}&rdquo;</p>
            <div class="mt-4 pt-4 border-t border-dashed border-brand-ink/15">
              <div class="text-xs uppercase tracking-[0.16em] text-brand-oxblood font-semibold">{item.source}</div>
              <div class="text-sm text-brand-ink/55 mt-1 group-hover:text-brand-oxblood transition-colors">{item.title}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AWARDS PREVIEW -->
  <section class="relative overflow-hidden bg-brand-cream">
    <div class="absolute inset-y-0 right-0 w-[44%] overflow-hidden hidden lg:block pointer-events-none">
      <Image
        src={portraitAlt}
        alt=""
        aria-hidden="true"
        widths={[480, 640, 900]}
        sizes="44vw"
        quality={68}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover object-top opacity-[0.20] mix-blend-multiply"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-cream via-brand-cream/65 to-transparent"></div>
    </div>
    <div class="section-container relative">
      <p class="section-eyebrow">Recognition</p>
      <h2 class="section-heading">Awards &amp; Honors</h2>
      <div class="grid sm:grid-cols-2 gap-px bg-brand-ink/10 mt-8">
        {featuredAwards.map((award) => (
          <div class="bg-brand-cream p-6">
            <div class="font-display text-xl text-brand-ink">{award.name}</div>
            {award.work && <div class="text-sm text-brand-ink/55 mt-1">{award.work}{award.year ? ` · ${award.year}` : ''}</div>}
          </div>
        ))}
      </div>
      <a href="/awards" class="btn-outline mt-8 inline-flex">View All Awards</a>
    </div>
  </section>

  <!-- PRESS PREVIEW -->
  <section class="bg-brand-ink text-brand-cream">
    <div class="section-container">
      <p class="section-eyebrow text-brand-gold">In the Press</p>
      <h2 class="section-heading text-brand-cream">Recent Coverage</h2>
      <div class="space-y-1 mt-8">
        {featuredPress.map((item) => (
          <a href={item.url} target="_blank" rel="noopener" class="flex items-center justify-between py-5 border-b border-brand-cream/10 group">
            <div>
              <div class="text-xs uppercase tracking-[0.18em] text-brand-gold mb-1">{item.outlet} {item.date && `· ${item.date}`}</div>
              <div class="font-serif text-lg text-brand-cream group-hover:text-brand-goldBright transition-colors">{item.title}</div>
            </div>
            <span class="text-brand-cream/55 group-hover:text-brand-goldBright transition-colors">↗</span>
          </a>
        ))}
      </div>
      <a href="/press" class="btn-primary mt-10 inline-flex">All Press Coverage</a>
    </div>
  </section>
</BaseLayout>
