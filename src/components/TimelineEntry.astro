---
import { Image } from 'astro:assets';
import type { TimelineEntry as TimelineEntryType } from '@data/timeline';
import { getProductionHref, getFeaturedThumbnail } from '@data/productions';

interface Props {
  entry: TimelineEntryType;
  isLast?: boolean;
}
const { entry, isLast = false } = Astro.props;

const categoryColor: Record<string, string> = {
  Career: 'bg-brand-gold',
  Production: 'bg-brand-oxbloodBright',
  Award: 'bg-brand-goldBright',
};

const openByDefault = entry.category !== 'Production';
const productionHref = entry.category === 'Production' ? getProductionHref(entry.title) : null;
const thumbnail = entry.category === 'Production' ? getFeaturedThumbnail(entry.title) : null;
---
<li class="relative pl-9 md:pl-12" data-category={entry.category}>
  <span
    class:list={['absolute left-0 md:left-1 top-2 w-3 h-3 rounded-full ring-[3px] ring-white shadow-sm', categoryColor[entry.category]]}
    aria-hidden="true"
  ></span>
  {!isLast && (
    <span class="absolute left-[5px] md:left-[11px] top-5 bottom-0 w-px bg-brand-ink/20" aria-hidden="true"></span>
  )}

  <details class="group pb-7" open={openByDefault}>
    <summary class="cursor-pointer list-none flex items-start gap-3 [&::-webkit-details-marker]:hidden">
      {thumbnail && (
        <a href={productionHref} class="shrink-0 block w-14 h-14 overflow-hidden bg-brand-ink/5">
          <Image
            src={thumbnail.src}
            alt=""
            widths={[112]}
            sizes="56px"
            quality={72}
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </a>
      )}
      <span class="flex flex-wrap items-baseline gap-x-4 gap-y-1 flex-1 pt-0.5">
        <span class="font-display text-xl md:text-2xl text-brand-oxblood tracking-tight tabular-nums shrink-0">{entry.year}</span>
        {productionHref ? (
          <a
            href={productionHref}
            class="font-display text-lg md:text-xl text-brand-ink hover:text-brand-oxblood transition-colors"
          >
            {entry.title}
          </a>
        ) : (
          <span class="font-display text-lg md:text-xl text-brand-ink">{entry.title}</span>
        )}
        {entry.venue && <span class="text-xs uppercase tracking-[0.14em] text-brand-ink/65">{entry.venue}</span>}
        <span class="ml-auto text-brand-ink/30 text-sm transition-transform group-open:rotate-180" aria-hidden="true">&#9662;</span>
      </span>
    </summary>
    <p class:list={['font-serif text-brand-ink/70 mt-2 max-w-2xl leading-relaxed text-[0.95rem]', { 'pl-[68px]': thumbnail }]}>
      {entry.description}
    </p>
  </details>
</li>
