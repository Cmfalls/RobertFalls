---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import { awards } from '@data/awards';
import { getProductionHref, productions } from '@data/productions';
import rehearsalPhoto from '../images/falls-rehearsal-recent.jpg';

const featuredAwards = awards.filter((award) =>
  /Tony|Drama Desk|Obie|Hall of Fame|Helen Hayes/i.test(award.name),
);
const archiveAwards = awards.filter((award) => !featuredAwards.includes(award));
const productionTitles = new Set(productions.map((production) => production.title.toLowerCase()));
const personalFeaturedCount = featuredAwards.filter((award) => !/Goodman Theatre/i.test(award.work ?? '')).length;
const institutionalCount = awards.filter((award) =>
  /Goodman Theatre|League of Chicago Theatres|Chicago Magazine|American Academy|Lawyers for the Creative Arts|Lake Forest College|Moscow Art Theatre|Eugene O.?Neill Society/i.test(
    `${award.name} ${award.work ?? ''}`,
  ),
).length;
const awardSpan = {
  first: awards.find((award) => award.year)?.year ?? '1976',
  latest: [...awards].reverse().find((award) => award.year)?.year ?? '2022-23',
};

function workHref(work?: string) {
  if (!work) return null;
  return productionTitles.has(work.toLowerCase()) ? getProductionHref(work) : null;
}

function awardType(award: (typeof awards)[number]) {
  if (/Goodman Theatre/i.test(award.work ?? '')) return 'Institutional honor';
  if (/Hall of Fame|Academy|Governor|Doctor/i.test(award.name)) return 'Career honor';
  return 'Production-linked honor';
}
---

<BaseLayout
  title="Awards & Honors — Robert Falls"
  description="Awards and honors received by theatre director Robert Falls, including a Tony Award, Drama Desk Award, Obie Award, and induction into the Theatre Hall of Fame."
>
  <section class="bg-brand-ink text-brand-cream relative overflow-hidden">
    <Image
      src={rehearsalPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={68}
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.18] mix-blend-luminosity pointer-events-none"
    />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(138,19,36,0.5),_transparent_52%),radial-gradient(ellipse_at_bottom_right,_rgba(201,162,39,0.1),_transparent_48%),linear-gradient(150deg,rgba(12,9,8,0.92),rgba(27,18,14,0.82))]"></div>
    <div class="grain-overlay"></div>
    <div class="relative pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="section-container !py-0">
        <p class="section-eyebrow text-brand-gold">Recognition</p>
        <h1 class="font-display font-extrabold text-6xl md:text-8xl tracking-tight">Awards &amp; Honors</h1>
        <p class="mt-5 max-w-3xl text-brand-cream/72 leading-relaxed">
          Robert Falls's individual honors appear first here, with broader Goodman and career-wide
          recognitions separated below so institutional achievements do not read like personal prize totals.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3 max-w-4xl">
          <div class="border border-brand-gold/20 bg-white/5 px-5 py-5">
            <div class="text-[10px] uppercase tracking-[0.2em] text-brand-gold font-semibold">Personal honors</div>
            <div class="mt-2 font-display text-4xl text-brand-cream">{personalFeaturedCount}</div>
            <div class="text-sm text-brand-cream/65 mt-1">major recognitions tied directly to Falls as a director</div>
          </div>
          <div class="border border-brand-gold/20 bg-white/5 px-5 py-5">
            <div class="text-[10px] uppercase tracking-[0.2em] text-brand-gold font-semibold">Award span</div>
            <div class="mt-2 font-display text-4xl text-brand-cream">{awardSpan.first}</div>
            <div class="text-sm text-brand-cream/65 mt-1">through {awardSpan.latest}, from early Chicago work to late-career honors</div>
          </div>
          <div class="border border-brand-gold/20 bg-white/5 px-5 py-5">
            <div class="text-[10px] uppercase tracking-[0.2em] text-brand-gold font-semibold">Institutional honors</div>
            <div class="mt-2 font-display text-4xl text-brand-cream">{institutionalCount}</div>
            <div class="text-sm text-brand-cream/65 mt-1">career-wide or institution-level recognitions kept distinct from personal wins</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-brand-ink text-brand-cream">
    <Image
      src={rehearsalPhoto}
      alt=""
      aria-hidden="true"
      widths={[640, 960, 1280, 1600]}
      sizes="100vw"
      quality={68}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-[0.22] mix-blend-luminosity pointer-events-none"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-ink/85 via-brand-ink/75 to-brand-ink/90"></div>
    <div class="grain-overlay"></div>
    <div class="section-container relative">
      <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
        <div>
          <p class="section-eyebrow text-brand-gold">Major Honors</p>
          <h2 class="font-display text-5xl md:text-6xl tracking-tight text-brand-cream mb-4">National and Career Recognition</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.18em] text-brand-cream/45">
          personal awards and headline distinctions
        </div>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {featuredAwards.map((award) => {
          const href = workHref(award.work);
          return (
            <article class="border border-brand-cream/15 bg-white/8 p-7 md:p-8 backdrop-blur-[2px]">
              <div class="flex items-start justify-between gap-4">
                <div class="text-[10px] uppercase tracking-[0.18em] text-brand-gold font-semibold">
                  {awardType(award)}
                </div>
                {award.year && (
                  <div class="text-[11px] uppercase tracking-[0.18em] text-brand-gold/80 font-semibold">
                    {award.year}
                  </div>
                )}
              </div>
              <h3 class="font-display text-3xl text-brand-cream leading-tight mt-4">{award.name}</h3>
              {award.work && (
                <div class="mt-4 text-sm text-brand-cream/60">
                  {href ? (
                    <a href={href} class="inline-flex items-center gap-2 text-brand-goldBright hover:text-brand-gold transition-colors">
                      <span>{award.work}</span>
                      <span aria-hidden="true">&rarr;</span>
                    </a>
                  ) : (
                    <span>{award.work}</span>
                  )}
                </div>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section-container">
    <div>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
        <div>
          <p class="section-eyebrow">Broader Recognition</p>
          <h2 class="section-heading">Institutional, Chicago, and Career Honors</h2>
        </div>
        <div class="text-xs uppercase tracking-[0.18em] text-brand-ink/55">
          chicago, institutional, and career-wide recognition
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-px bg-brand-ink/10">
        {archiveAwards.map((award) => {
          const href = workHref(award.work);
          return (
            <div class="bg-brand-cream p-7 flex flex-col gap-3">
              <div class="flex items-start justify-between gap-4">
                <div class="text-[10px] uppercase tracking-[0.18em] text-brand-oxblood font-semibold">
                  {awardType(award)}
                </div>
                {award.year && <div class="text-xs uppercase tracking-[0.16em] text-brand-ink/65">{award.year}</div>}
              </div>
              <div class="font-display text-2xl text-brand-ink leading-snug">{award.name}</div>
              {award.work && (
                <div class="text-sm text-brand-ink/60">
                  {href ? (
                    <a href={href} class="text-brand-oxblood hover:text-brand-oxbloodBright transition-colors">
                      {award.work}
                    </a>
                  ) : (
                    <span>{award.work}</span>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
