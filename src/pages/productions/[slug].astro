---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getRelatedProductions, getFeaturedThumbnail, productions, type ProductionRecord } from '@data/productions';

export function getStaticPaths() {
  return productions.map((production) => ({
    params: { slug: production.slug },
    props: { production },
  }));
}

interface Props {
  production: ProductionRecord;
}

const { production } = Astro.props;
const relatedProductions = getRelatedProductions(production.slug, 3);
const productionIndex = productions.findIndex((item) => item.slug === production.slug);
const previousProduction = productionIndex > 0 ? productions[productionIndex - 1] : null;
const nextProduction =
  productionIndex >= 0 && productionIndex < productions.length - 1 ? productions[productionIndex + 1] : null;
const heroImage = production.images.find((image) => image.priority) ?? production.images[0];
const isFeatured = production.pageMode === 'featured';
const heroImageIndex = heroImage ? production.images.findIndex((image) => image.src === heroImage.src) : -1;
const summary = production.publicSummary ?? production.summary;
const synopsis = production.synopsis ?? production.publicSummary ?? production.story ?? production.summary;
const fallsContext = production.fallsContext ?? production.significance;
const assetImages = production.images;
const featuredPreviewImages = isFeatured
  ? assetImages.filter((_, index) => index !== heroImageIndex).slice(0, 2)
  : [];
const hasAssets = assetImages.length > 0 || production.watchLinks.length > 0;
const hasFeaturedPreview = featuredPreviewImages.length > 0;
const hasReviews = production.reviews.length > 0;
const hasExternalSources = production.externalSources.length > 0;
const hasPressQuotes = production.pressQuotes.length > 0;
const hasAudienceFeedback = production.audienceFeedback.length > 0;
const hasPeople = production.cast.length > 0 || production.creativeTeam.length > 0;
const hasStory = Boolean(production.story);
const hasContextNotes = production.contextNotes.length > 0;
const hasHighlights = production.awardsOrSignificance.length > 0;
const hasReceptionSection = hasReviews || hasExternalSources || hasPressQuotes || hasAudienceFeedback;
const heroLinks = [
  { href: '#overview', label: 'Overview' },
  ...(hasAssets ? [{ href: '#assets-main', label: 'Media' }] : []),
  ...(hasPeople ? [{ href: '#credits-main', label: 'Credits' }] : []),
  ...(hasReceptionSection ? [{ href: '#press-main', label: 'Reception' }] : []),
];
const railFacts = production.quickFacts.some((fact) => /stagings?/i.test(fact.label))
  ? production.quickFacts
  : [...production.quickFacts, { label: 'Stagings', value: String(production.stagingCount) }];
const introFacts = [
  production.yearSpan,
  production.venueAnchor,
  production.eraLabel,
].filter(Boolean);
const siteBase = Astro.site ?? new URL('https://robertfalls.netlify.app');
const siteOrigin = new URL('/', siteBase).toString().replace(/\/$/, '');
const productionUrl = new URL(Astro.url.pathname, siteBase).toString();
const productionImages = production.images
  .slice(0, 6)
  .map((image) => new URL(image.src.src, siteBase).toString());
const productionSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
      { '@type': 'ListItem', position: 2, name: 'Productions', item: `${siteOrigin}/productions/` },
      { '@type': 'ListItem', position: 3, name: production.title, item: productionUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${productionUrl}#webpage`,
    url: productionUrl,
    name: `${production.title} — Robert Falls`,
    description: summary,
    isPartOf: { '@id': `${siteOrigin}/#website` },
    about: { '@id': `${productionUrl}#production` },
    ...(productionImages[0]
      ? {
          primaryImageOfPage: {
            '@type': 'ImageObject',
            url: productionImages[0],
          },
        }
      : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${productionUrl}#production`,
    url: productionUrl,
    name: production.title,
    description: synopsis,
    creator: { '@id': `${siteOrigin}/#person` },
    temporalCoverage: production.yearSpan,
    dateCreated: production.firstYear,
    keywords: [production.venueAnchor, production.eraLabel, ...production.venues].filter(Boolean),
    ...(productionImages.length > 0 ? { image: productionImages } : {}),
  },
];
---

<BaseLayout
  title={`${production.title} - Robert Falls`}
  description={summary}
  schema={productionSchema}
>
  <section class={`production-hero ${heroImage ? 'production-hero-with-image' : ''}`}>
    {heroImage && (
      <Image
        src={heroImage.src}
        alt=""
        aria-hidden="true"
        widths={[640, 960, 1280, 1600, 2000]}
        sizes="100vw"
        quality={78}
        loading="eager"
        fetchpriority="high"
        class="production-hero-image"
      />
    )}
    <div class="production-hero-bg"></div>
    <div class="production-hero-vignette"></div>
    <div class="grain-overlay"></div>
    <div class="production-hero-inner">
      <div class="production-hero-copy">
        <div class="production-breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/productions">Productions</a>
        </div>

        <div class="production-kicker-row">
          <span class="production-mode-pill">{isFeatured ? 'Editorial feature' : 'Archive record'}</span>
          {introFacts.map((fact) => (
            <span>{fact}</span>
          ))}
        </div>

        <h1>{production.title}</h1>
        <p>{summary}</p>

        <div class="production-hero-actions">
          {heroLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>

      {!heroImage && (
        <figure class="production-hero-media production-type-media">
          <div class="production-type-year">{production.yearSpan}</div>
          <div class="production-type-title">{production.title}</div>
        </figure>
      )}
    </div>
  </section>

  <div class="production-page">
    <section id="overview" class="production-main-grid">
      <div class="production-story-stack">
        <section class="production-overview-pair">
          <article class="production-panel production-intro-panel">
            <p class="production-eyebrow">Production summary</p>
            <h2>Overview</h2>
            <p>{synopsis}</p>
          </article>

          <article class="production-panel production-context-panel">
            <p class="production-eyebrow">Robert Falls context</p>
            <p>{fallsContext}</p>
          </article>
        </section>

        {hasFeaturedPreview && (
          <section class="production-feature-grid" aria-label="Featured production images">
            {featuredPreviewImages.map((image) => (
              <figure class="production-feature-card">
                <Image
                  src={image.src}
                  alt={image.alt}
                  widths={[520, 760, 1080, 1400]}
                  sizes="(max-width: 1024px) 100vw, 50vw"
                  quality={78}
                  loading="lazy"
                  class="production-feature-image"
                />
                <figcaption>{image.caption}</figcaption>
              </figure>
            ))}
          </section>
        )}

        {(hasStory || hasContextNotes) && (
          <section class="production-context-grid">
            {hasStory && (
              <article class="production-panel">
                <p class="production-eyebrow">Why it matters</p>
                <h2>Archive Perspective</h2>
                <p>{production.story}</p>
              </article>
            )}

            {hasContextNotes && (
              <article class="production-panel">
                <p class="production-eyebrow">Archive notes</p>
                <h2>Production History & Notes</h2>
                <div class="production-callouts production-callouts-spacious">
                  {production.contextNotes.map((item) => (
                    <article>
                      <h3>{item.label}</h3>
                      <p>{item.text}</p>
                    </article>
                  ))}
                </div>
              </article>
            )}
          </section>
        )}

        {false && (
        <section id="assets" class="production-assets-section">
          <div class="production-section-heading production-slider-heading">
            <div>
              <p class="production-eyebrow">Assets</p>
              <h2>Look & Listen</h2>
            </div>
            <div class="production-slider-cue" aria-hidden="true">
              <span>Scroll</span>
              <strong>← →</strong>
            </div>
          </div>

          {hasAssets ? (
            <div class="production-asset-strip" aria-label={`${production.title} production assets`}>
              {assetImages.map((image) => (
                <figure class="production-asset-card">
                  <img
                    src={image.src.src}
                    alt={image.alt}
                    width={image.src.width}
                    height={image.src.height}
                  />
                </figure>
              ))}
              {production.watchLinks.map((link) => (
                <a href={link.href} class="production-watch-card">
                  {link.thumbnail && (
                    <img
                      src={link.thumbnail.src}
                      alt=""
                      width={link.thumbnail.width}
                      height={link.thumbnail.height}
                    />
                  )}
                  <div class="production-watch-overlay"></div>
                  <span>Watch</span>
                  <strong>{link.label}</strong>
                  {link.description && <p>{link.description}</p>}
                </a>
              ))}
            </div>
          ) : (
            <div class="production-panel production-empty-visual">
              <p>Assets have not been attached for this production yet.</p>
            </div>
          )}
        </section>

        <section id="press" class="production-bottom-section">
          <div class="production-section-heading">
            <p class="production-eyebrow">Reception</p>
            <h2>Reviews & Links</h2>
          </div>

          <div class={`production-review-grid ${hasExternalSources ? 'production-review-grid-with-sources' : ''}`}>
            <div class="production-review-cards">
              {hasReviews ? (
                production.reviews.map((review) => (
                  <a href={review.href} class="production-review-card">
                    <span>{review.source}</span>
                    <p>{review.summary}</p>
                    <small>{review.note ?? 'Open link'}</small>
                  </a>
                ))
              ) : (
                <div class="production-panel production-empty-visual">
                  <p>Review cards have not been researched for this production yet.</p>
                </div>
              )}
            </div>

            {hasExternalSources && (
              <aside class="production-source-card">
                <p class="production-eyebrow">Sources</p>
                {production.externalSources.slice(0, 6).map((source) => (
                  <a href={source.href}>{source.label}</a>
                ))}
              </aside>
            )}
          </div>
        </section>
        )}
      </div>

      <aside class="production-side-rail" aria-label="Production facts and credits">
        <section class="production-rail-card">
          <p class="production-eyebrow">Quick facts</p>
          <dl class="production-facts">
            {railFacts.map((fact) => (
              <div>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>
        </section>

        {hasHighlights && (
          <section class="production-rail-card production-significance-card">
            <p class="production-eyebrow">Highlights</p>
            <div class="production-callouts">
              {production.awardsOrSignificance.slice(0, 3).map((item) => (
                <article>
                  <h3>{item.label}</h3>
                  <p>{item.detail}</p>
                </article>
              ))}
            </div>
          </section>
        )}
      </aside>
    </section>

    {hasAssets && (
    <section id="assets-main" class="production-assets-section production-assets-wide">
      <div class="production-section-heading production-slider-heading">
        <div>
          <p class="production-eyebrow">Gallery & media</p>
          <h2>{isFeatured ? 'Production Images' : 'Archive Material'}</h2>
        </div>
        <div class="hidden md:flex items-center gap-2">
          <button class="production-strip-btn" data-strip-prev aria-label="Scroll assets left">←</button>
          <span class="production-slider-note">Scroll</span>
          <button class="production-strip-btn" data-strip-next aria-label="Scroll assets right">→</button>
        </div>
      </div>

      <div class="production-asset-strip" aria-label={`${production.title} production assets`} data-asset-strip>
          {assetImages.map((image) => (
            <figure class="production-asset-card">
              <Image
                src={image.src}
                alt={image.alt}
                widths={[360, 540, 720, 960, 1280]}
                sizes="(max-width: 640px) 82vw, (max-width: 1024px) 21rem, 25vw"
                quality={78}
                loading="lazy"
                class="w-full"
              />
            </figure>
          ))}
          {production.watchLinks.map((link) => (
            <a href={link.href} class="production-watch-card">
              {link.thumbnail && (
                <Image
                  src={link.thumbnail}
                  alt=""
                  widths={[360, 540, 720, 960]}
                  sizes="(max-width: 640px) 82vw, (max-width: 1024px) 21rem, 25vw"
                  quality={72}
                  loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover opacity-70"
                />
              )}
              <div class="production-watch-overlay"></div>
              <span>Watch</span>
              <strong>{link.label}</strong>
              {link.description && <p>{link.description}</p>}
            </a>
          ))}
      </div>
    </section>
    )}

    {hasPeople && (
      <section id="credits-main" class="production-credits-section production-panel">
        <p class="production-eyebrow">Cast & creative</p>
        <div class="production-credit-columns">
          {production.cast.length > 0 && (
            <div class="production-people-group">
              <h3>Cast</h3>
              {production.cast.map((person) => (
                <div class="production-person-row">
                  <span>{person.role}</span>
                  <strong>{person.name}</strong>
                </div>
              ))}
            </div>
          )}
          {production.creativeTeam.length > 0 && (
            <div class="production-people-group">
              <h3>Creative</h3>
              {production.creativeTeam.map((person) => (
                <div class="production-person-row">
                  <span>{person.role}</span>
                  <strong>{person.name}</strong>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    {(hasReviews || hasExternalSources) && (
    <section id="press-main" class="production-bottom-section">
      <div class="production-section-heading">
        <p class="production-eyebrow">Reception</p>
        <h2>{hasReviews ? 'Reviews & Links' : 'Sources & Further Reading'}</h2>
      </div>

      <div class="production-review-grid">
        {hasReviews && (
          <div class="production-review-cards">
            {production.reviews.map((review) => (
              <a href={review.href} class="production-review-card">
                <span>{review.source}</span>
                <p>{review.summary}</p>
                <small>{review.note ?? 'Open link'}</small>
              </a>
            ))}
          </div>
        )}

        {hasExternalSources && (
          <aside class="production-source-card">
            <p class="production-eyebrow">{hasReviews ? 'Sources' : 'Reading list'}</p>
            {production.externalSources.slice(0, 6).map((source) => (
              <a href={source.href}>{source.label}</a>
            ))}
          </aside>
        )}
      </div>
    </section>
    )}

    {hasPressQuotes && (
      <section class="production-bottom-section">
        <div class="production-section-heading">
          <p class="production-eyebrow">Critical praise</p>
          <h2>What Critics Pulled Forward</h2>
        </div>

        <div class="production-quote-grid">
          {production.pressQuotes.map((item) => (
            <article class="production-quote-card">
              <p>{item.quote}</p>
              {item.href ? (
                <a href={item.href} class="production-quote-source">
                  {item.source}
                </a>
              ) : (
                <span class="production-quote-source">{item.source}</span>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {hasAudienceFeedback && (
      <section class="production-bottom-section">
        <div class="production-section-heading">
          <p class="production-eyebrow">Audience response</p>
          <h2>What Audiences Said</h2>
        </div>

        <div class="production-feedback-grid">
          {production.audienceFeedback.map((item) => (
            <article class="production-feedback-card">
              <p>{item.quote}</p>
              <div>
                <strong>{item.author}</strong>
                {item.source && <span>{item.source}</span>}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="production-related-section">
      <div class="production-section-heading">
        <p class="production-eyebrow">Related productions</p>
        <h2>Keep Browsing</h2>
      </div>

      <div class="production-related-grid">
        {relatedProductions.map((related) => {
          const relatedThumb = getFeaturedThumbnail(related.title);
          return (
            <a href={`/productions/${related.slug}`} class="group">
              {relatedThumb && (
                <div class="aspect-[3/2] overflow-hidden">
                  <Image
                    src={relatedThumb.src}
                    alt=""
                    widths={[320, 480, 640]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    quality={72}
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                  />
                </div>
              )}
              <div class="related-card-text">
                <span>{related.yearSpan}</span>
                <h3>{related.title}</h3>
                <p>{related.venueAnchor}</p>
              </div>
            </a>
          );
        })}
      </div>

      <nav class="production-browse-nav" aria-label="Production library navigation">
        <a href="/productions">
          <span>Library</span>
          <strong>All Productions</strong>
        </a>
        {previousProduction ? (
          <a href={`/productions/${previousProduction.slug}`}>
            <span>Previous</span>
            <strong>{previousProduction.title}</strong>
          </a>
        ) : (
          <div>
            <span>Previous</span>
            <strong>Start of archive</strong>
          </div>
        )}
        {nextProduction ? (
          <a href={`/productions/${nextProduction.slug}`}>
            <span>Next</span>
            <strong>{nextProduction.title}</strong>
          </a>
        ) : (
          <div>
            <span>Next</span>
            <strong>End of archive</strong>
          </div>
        )}
      </nav>
    </section>
  </div>
</BaseLayout>

<style>
  .production-hero {
    @apply relative min-h-[44rem] overflow-hidden bg-brand-inkDeep text-brand-cream;
  }
  .production-hero-image {
    @apply absolute inset-0 h-full w-full object-cover scale-[1.03];
  }
  .production-hero-bg {
    @apply absolute inset-0 bg-[radial-gradient(circle_at_16%_18%,_rgba(110,20,35,0.8),_transparent_34%),radial-gradient(circle_at_84%_20%,_rgba(201,162,39,0.18),_transparent_26%),linear-gradient(145deg,_rgba(12,9,8,0.98),_rgba(27,18,15,0.95))];
  }
  .production-hero-with-image .production-hero-bg {
    background-image:
      linear-gradient(90deg, rgba(12, 9, 8, 0.97) 0%, rgba(16, 10, 9, 0.88) 30%, rgba(16, 10, 9, 0.38) 58%, rgba(12, 9, 8, 0.86) 100%),
      linear-gradient(180deg, rgba(12, 9, 8, 0.55) 0%, transparent 28%, transparent 55%, rgba(12, 9, 8, 0.97) 100%);
  }
  .production-hero-vignette {
    @apply pointer-events-none absolute inset-0;
    box-shadow: inset 0 0 120px 20px rgba(12, 9, 8, 0.48);
  }
  .production-hero-inner {
    @apply relative mx-auto flex min-h-[44rem] max-w-7xl items-end px-6 pb-14 pt-28 md:pb-16 md:pt-36;
  }
  .production-breadcrumb {
    @apply mb-6 flex items-center gap-2 text-[11px] uppercase tracking-[0.18em] text-brand-cream text-opacity-60;
  }
  .production-breadcrumb a {
    @apply transition-colors duration-200 hover:text-brand-goldBright;
  }
  .production-kicker-row {
    @apply mb-5 flex flex-wrap gap-2;
  }
  .production-kicker-row span {
    @apply rounded-full border border-brand-cream border-opacity-20 bg-brand-cream bg-opacity-5 px-3 py-1.5 font-display text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cream text-opacity-75;
  }
  .production-mode-pill {
    @apply border-brand-gold border-opacity-45 bg-brand-gold bg-opacity-10 text-brand-goldBright;
  }
  .production-hero-copy h1 {
    @apply max-w-4xl font-display text-6xl font-extrabold leading-none tracking-normal text-brand-cream md:text-8xl;
  }
  .production-hero-copy p {
    @apply mt-6 max-w-2xl text-xl italic leading-relaxed text-brand-cream text-opacity-80 md:text-2xl;
  }
  .production-hero-actions {
    @apply mt-8 flex flex-wrap gap-3;
  }
  .production-hero-actions a {
    @apply inline-flex rounded-full border border-brand-cream border-opacity-20 bg-black bg-opacity-20 px-5 py-3 font-display text-xs font-semibold uppercase tracking-[0.16em] text-brand-cream text-opacity-80 transition-colors duration-200 hover:border-brand-gold hover:text-brand-goldBright;
  }
  .production-hero-media {
    @apply relative min-h-[22rem] overflow-hidden border border-white border-opacity-10 bg-black bg-opacity-30 shadow-[0_28px_80px_rgba(0,0,0,0.32)] md:min-h-[30rem];
  }
  .production-hero-media img {
    @apply h-full min-h-[22rem] w-full object-cover md:min-h-[30rem];
  }
  .production-hero-media figcaption {
    @apply absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent px-5 pb-5 pt-16 text-sm leading-relaxed text-brand-cream text-opacity-80;
  }
  .production-type-media {
    @apply flex min-h-[22rem] flex-col justify-end bg-[radial-gradient(circle_at_50%_20%,_rgba(201,162,39,0.16),_transparent_34%),linear-gradient(145deg,_rgba(30,22,18,0.92),_rgba(8,6,5,0.98))] p-6 md:min-h-[30rem];
  }
  .production-type-year {
    @apply font-display text-6xl leading-none text-brand-goldBright;
  }
  .production-type-title {
    @apply mt-3 max-w-lg font-display text-5xl font-bold leading-none text-brand-cream;
  }
  .production-page {
    @apply mx-auto max-w-7xl px-6 py-10 md:py-12;
  }
  .production-main-grid {
    @apply grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start xl:grid-cols-[minmax(0,1fr)_22rem];
  }
  .production-story-stack {
    @apply space-y-6;
  }
  .production-feature-grid {
    @apply grid gap-4 md:grid-cols-2;
  }
  .production-feature-card {
    @apply overflow-hidden border border-brand-ink border-opacity-10 bg-white bg-opacity-90 shadow-[0_18px_48px_rgba(34,24,20,0.08)];
  }
  .production-feature-image {
    @apply h-full w-full object-cover;
  }
  .production-feature-card figcaption {
    @apply border-t border-brand-ink border-opacity-10 px-5 py-4 text-sm leading-relaxed text-brand-ink text-opacity-70;
  }
  .production-panel,
  .production-rail-card,
  .production-review-card,
  .production-quote-card,
  .production-feedback-card,
  .production-source-card,
  .production-related-grid a,
  .production-browse-nav a,
  .production-browse-nav div {
    @apply border border-brand-ink border-opacity-10 bg-white bg-opacity-80 shadow-[0_14px_42px_rgba(34,24,20,0.055)];
  }
  .production-panel,
  .production-rail-card,
  .production-source-card,
  .production-quote-card,
  .production-feedback-card {
    @apply p-5 md:p-6;
  }
  .production-eyebrow {
    @apply mb-3 font-display text-[11px] font-bold uppercase tracking-[0.22em] text-brand-oxblood;
  }
  .production-section-heading h2,
  .production-panel h2 {
    @apply font-display text-4xl font-semibold leading-none tracking-normal text-brand-ink;
  }
  .production-panel p:not(.production-eyebrow) {
