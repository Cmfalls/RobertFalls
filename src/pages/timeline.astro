---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import MarqueeLights from '@components/MarqueeLights.astro';
import TimelineEntry from '@components/TimelineEntry.astro';
import { timelineEntries } from '@data/timeline';
import { getFeaturedThumbnail } from '@data/productions';
import wisdomBridgePhoto from '../images/falls-wisdom-bridge-rehearsal.jpg';

function decadeOf(yearStr: string): string {
  const year = parseInt(yearStr.slice(0, 4), 10);
  if (year < 1980) return '1954–79';
  if (year < 1990) return '1980s';
  if (year < 2000) return '1990s';
  if (year < 2010) return '2000s';
  if (year < 2020) return '2010s';
  return '2020s';
}

const decadeOrder = ['2020s', '2010s', '2000s', '1990s', '1980s', '1954–79'];
const defaultOpenDecades = new Set(['2010s', '2020s']);

const groups = decadeOrder
  .map((decade) => {
    const entries = timelineEntries.filter((e) => decadeOf(e.year) === decade).reverse();
    const previews = entries
      .map((e) => (e.category === 'Production' ? getFeaturedThumbnail(e.title) : null))
      .filter((img): img is NonNullable<typeof img> => img !== null)
      .slice(0, 3);
    return { decade, entries, previews };
  })
  .filter((g) => g.entries.length > 0);

function slug(decade: string) {
  return 'decade-' + decade.replace(/[^0-9a-z]+/gi, '-').toLowerCase();
}
---

<BaseLayout
  title="Timeline — Robert Falls"
  description="An interactive career timeline of theatre director Robert Falls, from 1954 to the present — Wisdom Bridge, the Goodman Theatre, Broadway, and beyond."
>
  <section class="bg-brand-ink text-brand-cream relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(138,19,36,0.38),_transparent_55%),radial-gradient(ellipse_at_bottom_right,_rgba(138,19,36,0.14),_transparent_45%)]"></div>
    <div class="absolute inset-y-0 right-0 w-full lg:w-[50%] overflow-hidden pointer-events-none">
      <Image
        src={wisdomBridgePhoto}
        alt=""
        aria-hidden="true"
        widths={[360, 480, 640, 900]}
        sizes="(max-width: 1023px) 100vw, 50vw"
        quality={68}
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover object-top opacity-[0.11] lg:opacity-[0.26]"
      />
      <div class="absolute inset-0 lg:hidden" style="background: linear-gradient(to right, rgba(12,9,8,0.90) 0%, rgba(12,9,8,0.68) 45%, rgba(12,9,8,0.90) 100%), linear-gradient(to bottom, rgba(12,9,8,0.45) 0%, transparent 45%, rgba(12,9,8,0.65) 100%);"></div>
      <div class="absolute inset-0 hidden lg:block bg-gradient-to-r from-brand-ink via-brand-ink/60 to-brand-ink/12"></div>
    </div>
    <div class="grain-overlay"></div>
    <div class="relative pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="section-container !py-0">
        <p class="section-eyebrow text-brand-gold">Seven Decades</p>
        <h1 class="font-display font-extrabold text-6xl md:text-8xl tracking-tight">Career Timeline</h1>
        <p class="font-serif italic text-brand-cream/70 text-lg mt-6 max-w-xl">
          From a childhood in Ashland, Illinois, to four decades shaping Chicago theatre — a life in the American stage.
        </p>
      </div>
      <MarqueeLights class="mt-12" />
    </div>
  </section>

  <section class="section-container max-w-3xl">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-8 pb-6 border-b border-brand-ink/10">
      <span class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-brand-ink/60">
        <span class="w-2.5 h-2.5 rounded-full bg-brand-gold inline-block shrink-0"></span> Career milestone
      </span>
      <span class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-brand-ink/60">
        <span class="w-2.5 h-2.5 rounded-full bg-brand-oxbloodBright inline-block shrink-0"></span> Production
      </span>
      <span class="flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-brand-ink/60">
        <span class="w-2.5 h-2.5 rounded-full bg-brand-goldBright inline-block shrink-0"></span> Award
      </span>
      <div class="ml-auto timeline-filter-shell" data-timeline-filters>
        <button type="button" class="filter-pill" data-filter="all" aria-pressed="true">All</button>
        <button type="button" class="filter-pill" data-filter="Career" aria-pressed="false">Career</button>
        <button type="button" class="filter-pill" data-filter="Production" aria-pressed="false">Productions</button>
        <button type="button" class="filter-pill" data-filter="Award" aria-pressed="false">Awards</button>
      </div>
    </div>

    <nav class="mb-10" aria-label="Jump to decade">
      <div class="text-[11px] uppercase tracking-[0.18em] text-brand-ink/50 mb-3">Jump to decade</div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {groups.map((g) => (
          <a href={`#${slug(g.decade)}`} class="jump-pill" data-jump-decade={slug(g.decade)}>{g.decade} <span class="text-brand-ink/35">({g.entries.length})</span></a>
        ))}
      </div>
    </nav>

    <div data-decade-list class="space-y-3">
      {groups.map((g) => (
        <details class="decade-group group border border-brand-ink/12" id={slug(g.decade)} open={defaultOpenDecades.has(g.decade)}>
          <summary class="decade-summary list-none cursor-pointer select-none flex items-center gap-4 px-5 py-5 border-l-[3px] border-brand-oxblood hover:bg-brand-ink/[0.04] transition-colors duration-150 [&::-webkit-details-marker]:hidden">
            <span class="font-display text-4xl md:text-5xl text-brand-oxblood leading-none tabular-nums">{g.decade}</span>
            <span class="text-[11px] uppercase tracking-[0.18em] text-brand-ink/45 font-semibold">{g.entries.length} entries</span>
            {g.previews.length > 0 && (
              <span class="hidden sm:flex items-center -space-x-2.5 ml-2">
                {g.previews.map((img) => (
                  <Image
                    src={img.src}
                    alt=""
                    widths={[96]}
                    sizes="48px"
                    quality={72}
                    loading="lazy"
                    class="w-12 h-12 rounded-full object-cover ring-2 ring-white"
                  />
                ))}
              </span>
            )}
            <svg class="ml-auto w-5 h-5 text-brand-ink/35 transition-transform duration-200 group-open:rotate-180 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <ul class="relative pt-5 px-5 pb-2">
            {g.entries.map((entry, i) => (
              <TimelineEntry entry={entry} isLast={i === g.entries.length - 1} />
            ))}
          </ul>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .timeline-filter-shell {
    @apply inline-flex flex-wrap gap-1.5 border border-brand-ink/15 bg-white/70 p-1 shadow-[0_8px_24px_rgba(34,24,20,0.07)];
  }
  .filter-pill {
    @apply px-3.5 py-1.5 text-[11px] font-display font-semibold uppercase tracking-[0.18em] border border-transparent text-brand-ink/60 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-cream;
  }
  .filter-pill[aria-pressed='true'] {
    @apply bg-brand-oxblood border-brand-oxblood text-brand-cream;
  }
  .jump-pill {
    @apply text-xs font-display font-semibold uppercase tracking-[0.16em] text-brand-oxblood/70 underline decoration-brand-oxblood/20 underline-offset-[0.35rem] transition-colors duration-200 hover:text-brand-oxblood focus-visible:outline-none focus-visible:text-brand-oxblood focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2 focus-visible:ring-offset-brand-cream;
  }
  .decade-group[open] > .decade-summary {
    @apply border-b border-brand-ink/10;
  }
</style>

<script>
  const filterBar = document.querySelector('[data-timeline-filters]');
  const decadeList = document.querySelector('[data-decade-list]');

  if (filterBar && decadeList) {
    const buttons = filterBar.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const items = decadeList.querySelectorAll<HTMLElement>('li[data-category]');
    const decadeDetails = decadeList.querySelectorAll<HTMLDetailsElement>('details.decade-group');

    filterBar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('[data-filter]');
      if (!btn) return;
      const filter = btn.dataset.filter;

      buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      items.forEach((li) => {
        const show = filter === 'all' || li.dataset.category === filter;
        li.classList.toggle('hidden', !show);
      });

      decadeDetails.forEach((details) => {
        const visibleCount = details.querySelectorAll('li[data-category]:not(.hidden)').length;
        details.classList.toggle('hidden', visibleCount === 0);
        // Expand decades that contain matches for a non-"all" filter so results are immediately visible
        if (filter !== 'all' && visibleCount > 0) details.open = true;
      });
    });
  }

  // Clicking a "jump to decade" pill should expand that decade before the browser scrolls to it
  document.querySelectorAll<HTMLAnchorElement>('[data-jump-decade]').forEach((link) => {
    link.addEventListener('click', () => {
      const target = document.getElementById(link.dataset.jumpDecade || '');
      if (target instanceof HTMLDetailsElement) target.open = true;
    });
  });

  // Deep-link support: if the page loads with a #decade-xxxx hash, expand it
  if (location.hash.startsWith('#decade-')) {
    const target = document.querySelector<HTMLDetailsElement>(location.hash);
    if (target) target.open = true;
  }
</script>
